class Solution {
    public int maxArea(int[] height) {
        int area, maxArea = 0;
        int n = height.length;
        int left = 0, right = n-1;
        while(left < right){
            area = (height[left]<height[right] ? height[left] : height[right]) * (right - left);
            maxArea = area>maxArea ? area : maxArea;
            if(height[left] < height[right]){
                left++;
            }else{
                right--;
            }
        }
        return maxArea;
    }
}
